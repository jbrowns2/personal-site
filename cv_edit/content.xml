l-width="0.1965in"/></text:list-level-style-bullet><text:list-level-style-bullet text:level="9" text:style-name="Bullet_20_Symbols" loext:num-list-format="%9%." style:num-suffix="." text:bullet-char="•"><style:list-level-properties text:space-before="4.2346in" text:min-label-width="0.1965in"/></text:list-level-style-bullet><text:list-level-style-bullet text:level="10" text:style-name="Bullet_20_Symbols" loext:num-list-format="%10%." style:num-suffix="." text:bullet-char="•"><style:list-level-properties text:space-before="4.7272in" text:min-label-width="0.1965in"/></text:list-level-style-bullet></text:list-style></office:automatic-styles><office:body><office:text text:use-soft-page-breaks="true"><text:sequence-decls><text:sequence-decl text:display-outline-level="0" text:name="Illustration"/><text:sequence-decl text:display-outline-level="0" text:name="Table"/><text:sequence-decl text:display-outline-level="0" text:name="Text"/><text:sequence-decl text:display-outline-level="0" text:name="Drawing"/><text:sequence-decl text:display-outline-level="0" text:name="Figure"/></text:sequence-decls><text:h text:style-name="P1" text:outline-level="1"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T1">JONATHAN BROWNSTEIN, MSE, FLMI</text:span></text:span></text:h><text:p text:style-name="P2"/><text:p text:style-name="P3">Internal application — Ref. 3047 — <text:span text:style-name="T2">AVP</text:span>, ReFlex Underwriting Solutions (ReFlex &amp; ReFlex Select · U.S. Life Solutions)</text:p><text:p text:style-name="P2"/><text:h text:style-name="P4" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">EXECUTIVE SUMMARY</text:span></text:span></text:h><text:p text:style-name="P5"><text:span text:style-name="T3">Impact: </text:span><text:span text:style-name="T5">Analytics leader with </text:span><text:span text:style-name="T3">15+ years</text:span><text:span text:style-name="T5"> in insurance and reinsurance, including U.S. life reinsurance. </text:span><text:span text:style-name="T3">MS Economics</text:span><text:span text:style-name="T5"> and </text:span><text:span text:style-name="T3">FLMI</text:span><text:span text:style-name="T5">. At Hannover Re: production forecasting and ML (including </text:span><text:span text:style-name="T3">Databricks</text:span><text:span text:style-name="T5">-based workflows), enterprise metadata and lineage (Field Inventory Report architecture), and valuation-grade analytics at scale—strengthening underwriting-adjacent data quality, integration-ready enterprise references, and decision-support for actuarial and finance. CEO-level recognition on Same-As-Link (SAL) modernization; sustained governed, audit-ready analytics.</text:span></text:p><text:p text:style-name="P5"><text:span text:style-name="T3">Delivery: </text:span><text:span text:style-name="T5">Plans and drives complex analytics delivery across IT, actuarial, underwriting-aligned partners, data engineering, BI, and governance—informing prioritization and feasibility, aligning scope to capacity, and owning compliant production releases with predictable quality through reusable architecture and audit-suitable documentation.</text:span></text:p><text:p text:style-name="P5"><text:span text:style-name="T3">Role alignment (AVP, ReFlex Underwriting Solutions): </text:span><text:span text:style-name="T5">Experience supporting Hannover Re’s automated underwriting ecosystem—</text:span><text:span text:style-name="T3">ReFlex</text:span><text:span text:style-name="T5"> and </text:span><text:span text:style-name="T3">ReFlex Select</text:span><text:span text:style-name="T5"> priorities—through digital underwriting workflows, third-party and multi-channel underwriting data integrated into governed analytics layers, and iterative delivery patterns aligned with agile product execution—translating portfolio complexity into reliable underwriting and valuation capabilities.</text:span></text:p><text:p text:style-name="P2"/><text:h text:style-name="P4" text:outline-level="2"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">ARCHITECTURE &amp; TECHNICAL EXPERTISE</text:span></text:span></text:h><text:h text:style-name="P6" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Machine Learning &amp; Advanced Analytics</text:span></text:span></text:h><text:list text:style-name="L1"><text:list-item><text:p text:style-name="P7">Time series forecasting (ARIMA)</text:p></text:list-item><text:list-item><text:p text:style-name="P8">Classification models</text:p></text:list-item><text:list-item><text:p text:style-name="P8">Statistical modeling and applied econometrics</text:p></text:list-item><text:list-item><text:p text:style-name="P8">Outlier and anomaly detection <text:span text:style-name="T2">using probability density functions (PDFs)</text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P8">Model deployment, monitoring, and lifecycle governance</text:p></text:list-item></text:list><text:h text:style-name="P6" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Platforms &amp; Tools</text:span></text:span></text:h><text:list text:style-name="L2"><text:list-item><text:p text:style-name="P9">Python, R, SQL, VBA</text:p></text:list-item><text:list-item><text:p text:style-name="P10">Databricks, Power BI, SSRS, Tableau, <text:span text:style-name="T7">Visio</text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P10">Relational databases</text:p></text:list-item><text:list-item><text:p text:style-name="P10">Underwriting-adjacent data integration patterns supporting automated decision-support deployments</text:p></text:list-item><text:list-item><text:p text:style-name="P10">AI-assisted engineering workflows</text:p></text:list-item></text:list><text:h text:style-name="P6" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Industry Focus</text:span></text:span></text:h><text:list text:style-name="L3"><text:list-item><text:p text:style-name="P11">Insurance and reinsurance analytics</text:p></text:list-item><text:list-item><text:p text:style-name="P12">Financial risk and valuation</text:p></text:list-item><text:list-item><text:p text:style-name="P12">Actuarial and regulatory data environments</text:p></text:list-item><text:list-item><text:p text:style-name="P12">Automated underwriting ecosystems—rules-informed workflows, digital distribution, third-party data channels, and enterprise underwriting workflow integration</text:p></text:list-item><text:list-item><text:p text:style-name="P12">Third-party underwriting data (prescription histories, motor vehicle records, labs, medical claims, related feeds) governed through analytics layers feeding underwriting-adjacent models</text:p></text:list-item></text:list><text:h text:style-name="P13" text:outline-level="2"><text:soft-page-break/><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">PROFESSIONAL EXPERIENCE</text:span></text:span></text:h><text:h text:style-name="P6" text:outline-level="3"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Hannover Reinsurance Company LLC</text:span></text:span></text:h><text:p text:style-name="P14"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Senior Data Analyst III</text:span></text:span><text:span text:style-name="T8"> | 2019 – Present</text:span></text:p><text:p text:style-name="P14"><text:span text:style-name="T8">Title: Senior Data Analyst III; operates as </text:span><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Data Scientist &amp; ML Architect</text:span></text:span><text:span text:style-name="T8"> in </text:span><text:span text:style-name="T10">Data Analytics Operations</text:span><text:span 