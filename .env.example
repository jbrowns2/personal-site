# Neon — pooled serverless connection string recommended:
# https://neon.tech/docs/connect/connection-string
# After pulling gate updates, run neon/schema.sql (new DB) or neon/migration-002-brute-force.sql (existing).
DATABASE_URL=

# From: node scripts/hash-gate-code.js YOUR_ACCESS_CODE
ACCESS_CODE_BCRYPT=

# Min 32 chars, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATE_SESSION_SECRET=
