# Neon — pooled serverless connection string recommended:
# https://neon.tech/docs/connect/connection-string
# After pulling gate updates, run the SQL files in neon/ in order:
#   1. neon/schema.sql                          (new DB only)
#   2. neon/migration-002-brute-force.sql       (existing DBs missing brute-force tables)
#   3. neon/migration-003-access-codes.sql      (DB-backed access codes)
#   4. neon/migration-004-access-requests.sql   (visitor "Request access" form)
DATABASE_URL=

# Access codes now live in the DB. Manage with:
#   npm run gate:add -- "RAW CODE" "Label / company"
#   npm run gate:list
# ACCESS_CODE_BCRYPT below is OPTIONAL — leave blank in normal use. If set, its
# newline-separated bcrypt hashes are accepted as a fallback in addition to
# whatever is in the portfolio_gate_access_codes table (handy for emergencies
# or one-off bootstraps).
ACCESS_CODE_BCRYPT=

# Min 32 chars, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Also used to HMAC-sign /api/approve-access tokens (override via
# REQUEST_APPROVAL_SECRET if you want a separate secret).
GATE_SESSION_SECRET=

# Optional: dedicated secret for /api/approve-access token signing.
# Defaults to GATE_SESSION_SECRET when unset. Min 32 chars.
REQUEST_APPROVAL_SECRET=

# ---------------------------------------------------------------------------
# Resend transactional email — powers the "Request access" workflow
# (POST /api/request-access + /api/approve-access). All three RESEND_* vars
# must be set for the form to function; with any missing the API returns 503
# and the UI surfaces a "request form isn't wired up" message.
#
# Setup:
#   1. Create an API key at https://resend.com/api-keys.
#   2. Verify your sending domain (RESEND_FROM_EMAIL must use that domain).
#   3. Pick the inbox where new requests should land (RESEND_NOTIFY_EMAIL).
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="Jonathan Brownstein <portal@yourdomain.com>"
RESEND_NOTIFY_EMAIL=

# Public origin used to build approval links in outbound emails. If unset,
# the request-access handler infers from the inbound request headers
# (x-forwarded-proto / x-forwarded-host). Set this in production to be safe.
SITE_URL=https://www.yourdomain.com
