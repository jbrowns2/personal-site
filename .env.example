# Neon — pooled serverless connection string recommended:
# https://neon.tech/docs/connect/connection-string
# After pulling gate updates, run the SQL files in neon/ in order:
#   1. neon/schema.sql                          (new DB only)
#   2. neon/migration-002-brute-force.sql       (existing DBs missing brute-force tables)
#   3. neon/migration-003-access-codes.sql      (DB-backed access codes)
DATABASE_URL=

# Access codes now live in the DB. Manage with:
#   npm run gate:add -- "RAW CODE" "Label / company"
#   npm run gate:list
# ACCESS_CODE_BCRYPT below is OPTIONAL — leave blank in normal use. If set, its
# newline-separated bcrypt hashes are accepted as a fallback in addition to
# whatever is in the portfolio_gate_access_codes table (handy for emergencies
# or one-off bootstraps).
ACCESS_CODE_BCRYPT=

# Min 32 chars, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATE_SESSION_SECRET=
